# Matriz inicial
matriz = [
    [5, 2, 9],
    [8, 1, 3],
    [4, 7, 6]
]

print("Matriz original:")
for fila in matriz:
    print(fila)

# Eliminamos la segunda fila usando pop()
matriz.pop(1)

# Ordenamos la primera fila usando sort()
matriz[0].sort()

print("\nMatriz modificada:")
for fila in matriz:
    print(fila)