# Programa que crea una matriz ingresando datos

matriz = []  # matriz vacía

filas = int(input("Ingrese número de filas: "))
columnas = int(input("Ingrese número de columnas: "))

# Construimos la matriz
for i in range(filas):
    fila = []
    
    for j in range(columnas):
        valor = float(input(f"Ingrese valor [{i}][{j}]: "))
        fila.append(valor)  # usamos método append
    
    matriz.append(fila)  # agregamos la fila a la matriz

print("\nMatriz ingresada:")
for fila in matriz:
    print(fila)